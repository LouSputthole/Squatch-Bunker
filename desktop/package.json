{
  "name": "campfire-desktop",
  "version": "0.0.2",
  "description": "Campfire — Discord-like voice & text chat (portable Windows desktop app)",
  "main": "main.js",
  "author": "Squatch Bunker",
  "license": "AGPL-3.0-only",
  "scripts": {
    "start": "electron .",
    "icons": "node scripts/make-icons.mjs",
    "build:all": "node build-desktop.mjs",
    "build:portable": "node build-desktop.mjs --portable",
    "build:installer": "node build-desktop.mjs --installer"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.28.1"
  },
  "build": {
    "appId": "com.squatchbunker.campfire",
    "productName": "Campfire",
    "copyright": "© 2026 Squatch Bunker",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "icons"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "icons/icon.ico",
      "icons/icon.png",
      "icons/tray-icon.png"
    ],
    "extraResources": [
      {
        "from": "../squatch-chat/.next/standalone",
        "to": "server",
        "filter": ["**/*", "!.env", "!.env.*", "!**/*.db", "!**/*.db-*", "!data${/*}"]
      },
      { "from": "../squatch-chat/.next/static", "to": "server/.next/static" },
      { "from": "../squatch-chat/public", "to": "server/public" },
      { "from": "db-migrations", "to": "db-migrations" }
    ],
    "win": {
      "target": [
        { "target": "dir" },
        { "target": "nsis" }
      ],
      "icon": "icons/icon.ico",
      "publisherName": "Squatch Bunker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icons/icon.ico",
      "uninstallerIcon": "icons/icon.ico",
      "installerHeaderIcon": "icons/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Campfire",
      "artifactName": "Campfire-Setup-${version}-${arch}.${ext}"
    }
  }
}
