generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String    @id @default(uuid())
  email          String    @unique
  username       String    @unique
  passwordHash   String
  avatar         String?
  statusMessage  String?
  isGuest        Boolean   @default(false)
  guestExpiresAt DateTime?
  tier           String    @default("free")
  tierExpiresAt  DateTime?
  stripeCustomerId     String?
  stripeSubscriptionId String?
  subscriptionStatus   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships    ServerMember[]
  messages       Message[]
  reactions      Reaction[]
  bookmarks      Bookmark[]
  ownedServers   Server[]
  conversations1 Conversation[]          @relation("ConvUser1")
  conversations2 Conversation[]          @relation("ConvUser2")
  directMessages DirectMessage[]
  sentRequests   Friendship[]   @relation("FriendRequester")
  recvRequests   Friendship[]   @relation("FriendAddressee")
  dmReactions    DirectMessageReaction[]
}

model Server {
  id          String   @id @default(uuid())
  name        String
  icon        String?
  banner      String?
  ownerId     String
  createdAt   DateTime @default(now())
  inviteCode  String   @unique @default(uuid())
  isPublic    Boolean  @default(false)
  description String?

  owner        User           @relation(fields: [ownerId], references: [id])
  members      ServerMember[]
  channels     Channel[]
  webhooks     Webhook[]
  customEmojis CustomEmoji[]
  auditLogs    AuditLog[]
}

model ServerMember {
  id        String    @id @default(uuid())
  serverId  String
  userId    String
  role      String    @default("member")
  banned    Boolean   @default(false)
  bannedAt  DateTime?
  createdAt DateTime  @default(now())

  server Server @relation(fields: [serverId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([serverId, userId])
}

model Channel {
  id              String   @id @default(uuid())
  serverId        String
  name            String
  type            String   @default("text")
  category        String?
  description     String?
  topic           String?
  slowModeSeconds Int      @default(0)
  createdAt       DateTime @default(now())

  server      Server              @relation(fields: [serverId], references: [id])
  messages    Message[]
  permissions ChannelPermission[]
  webhooks    Webhook[]
}

model Message {
  id              String    @id @default(uuid())
  channelId       String
  authorId        String
  content         String
  attachmentUrl   String?
  attachmentName  String?
  replyToId       String?
  pinned          Boolean   @default(false)
  parentMessageId String?
  editedAt        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  channel   Channel    @relation(fields: [channelId], references: [id])
  author    User       @relation(fields: [authorId], references: [id])
  replyTo   Message?   @relation("MessageReplies", fields: [replyToId], references: [id])
  replies   Message[]  @relation("MessageReplies")
  reactions Reaction[]
  bookmarks Bookmark[]
  parent    Message?   @relation("thread", fields: [parentMessageId], references: [id])
  children  Message[]  @relation("thread")
}

model Reaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId, emoji])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  messageId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
}

model Conversation {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user1    User            @relation("ConvUser1", fields: [user1Id], references: [id])
  user2    User            @relation("ConvUser2", fields: [user2Id], references: [id])
  messages DirectMessage[]

  @@unique([user1Id, user2Id])
}

model DirectMessage {
  id             String    @id @default(uuid())
  conversationId String
  authorId       String
  content        String
  attachmentUrl  String?
  attachmentName String?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation            @relation(fields: [conversationId], references: [id])
  author       User                    @relation(fields: [authorId], references: [id])
  reactions    DirectMessageReaction[]
}

model DirectMessageReaction {
  id              String   @id @default(uuid())
  directMessageId String
  userId          String
  emoji           String
  createdAt       DateTime @default(now())

  directMessage DirectMessage @relation(fields: [directMessageId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])

  @@unique([directMessageId, userId, emoji])
}

model Webhook {
  id        String   @id @default(uuid())
  channelId String
  serverId  String
  name      String
  token     String   @unique @default(uuid())
  createdBy String
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id])
  server  Server  @relation(fields: [serverId], references: [id])
}

model CustomEmoji {
  id        String   @id @default(uuid())
  serverId  String
  name      String
  url       String
  createdBy String
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id])

  @@unique([serverId, name])
}

model AuditLog {
  id        String   @id @default(uuid())
  serverId  String
  actorId   String
  targetId  String?
  action    String
  detail    String?
  createdAt DateTime @default(now())

  server Server @relation(fields: [serverId], references: [id])
}

model ChannelPermission {
  id        String   @id @default(uuid())
  channelId String
  role      String
  canView   Boolean  @default(true)
  canSend   Boolean  @default(true)
  createdAt DateTime @default(now())

  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([channelId, role])
}

model Friendship {
  id          String   @id @default(uuid())
  requesterId String
  addresseeId String
  status      String   @default("pending") // pending, accepted, blocked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id])
  addressee User @relation("FriendAddressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
}
