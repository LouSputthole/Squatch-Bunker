# Explicit mode: Community is free AGPL self-host/desktop; Cloud is managed.
CAMPFIRE_EDITION="community"


# ─── Database ───
DATABASE_URL="file:./data/campfire.db"
# Cloud DATABASE_URL="postgresql://user:password@host:5432/campfire?schema=public"
# PostgreSQL uses `npm run db:migrate`; SQLite uses `npm run db:sync`.
# The production Compose path is PostgreSQL-only. Use a URL-safe random value:
# DB_PASSWORD="<output of: openssl rand -hex 32>"


# ─── Auth ───
# CHANGE THIS in production — generate with: openssl rand -hex 32
JWT_SECRET="campfire-secret-change-me-in-production"
# Cookie name (change if running multiple instances)
# COOKIE_NAME="squatch-token"

# Global /admin analytics are deny-by-default. Allow only immutable User IDs,
# comma-separated; usernames and "*" are not accepted.
# INSTANCE_ADMIN_USER_IDS="user-uuid-1,user-uuid-2"

# ─── Server URLs ───
# Browser runtime URLs are normally inferred by `npm run host`. Set the canonical
# public HTTPS URL when using password email, OAuth, or Stripe; those flows cannot
# rely on request-time inference.
# NEXT_PUBLIC_APP_URL="https://campfire.example.com"
# Single-port deployments should leave NEXT_PUBLIC_SOCKET_URL unset.
# NEXT_PUBLIC_SOCKET_URL="https://campfire.example.com"
# Self-hosted defaults to all interfaces for LAN access. Desktop builds
# override this to 127.0.0.1 so the embedded server stays local to the PC.
# CAMPFIRE_BIND_HOST="0.0.0.0"
SOCKET_PORT=3001

# Authentication rate limits ignore forwarding headers by default. Set this to
# the exact number of trusted reverse-proxy hops only when the outermost proxy
# replaces caller-supplied X-Forwarded-For. A direct public process must leave
# it unset. One local Caddy/Nginx proxy normally means 1.
# CAMPFIRE_TRUST_PROXY_HOPS=1


# ─── Socket.IO Path ───
# Change if running behind a reverse proxy that remaps the path
# SOCKET_PATH="/api/socketio"
# NEXT_PUBLIC_SOCKET_PATH="/api/socketio"

# ─── CORS ───
# By default, Campfire accepts connections from any origin (self-hosted mode).
# Set STRICT_CORS=true and CORS_ORIGINS to lock it down.
# STRICT_CORS=true
# CORS_ORIGINS="https://campfire.example.com,https://www.campfire.example.com"

# ─── Voice / WebRTC ───
# STUN works for most LAN setups. For internet voice calls, add a TURN server.
# Free options: https://www.metered.ca/stun-turn or run your own with coturn.
# TURN_URL="turn:your-turn-server.com:3478"
# TURN_USERNAME="your-username"
# TURN_CREDENTIAL="your-credential"

# Dormant SFU groundwork. All three values mark the backend configured, but
# `sfu_voice` remains planned and unavailable until the client/deployment path
# ships. Unset means rooms stay on the WebRTC mesh.
# LIVEKIT_URL="wss://your-livekit-server.com"
# LIVEKIT_API_KEY="your-api-key"
# LIVEKIT_API_SECRET="your-api-secret"

# ─── Upload Limits ───
# MAX_AVATAR_SIZE=2097152    # 2MB
# MAX_UPLOAD_SIZE=10485760   # 10MB
# Optional writable media root. When set, Campfire uses <root>/uploads and
# <root>/avatars for public media and <root>/private-uploads for authenticated
# message/DM attachments. Without it, those roots are public/ and
# data/private-uploads respectively.
# CAMPFIRE_UPLOAD_DIR="/var/lib/campfire/media"

# ─── Account recovery email ───
# Password-reset delivery uses Resend. Optional for Community deployments;
# required for CAMPFIRE_EDITION="cloud" in production.
# RESEND_API_KEY="re_..."
# CAMPFIRE_EMAIL_FROM="Campfire <account@campfire.example.com>"
# NEXT_PUBLIC_APP_URL must also be set to the public base URL above.

# ─── Billing / Stripe (managed/hosted mode only) ───
# Leave ALL of these unset for self-hosted mode — billing is disabled and every
# feature is unlocked. They are only needed to run the paid "premium" tier.
# Current policy: billing activates only in CAMPFIRE_EDITION="cloud" when all
# four Stripe settings are present. A Stripe key never selects an edition.
# Community unlocks every feature that is actually shipped.
#
# Secret key from https://dashboard.stripe.com/apikeys (use sk_test_… in dev).
# STRIPE_SECRET_KEY="sk_test_..."
# Signing secret for the webhook endpoint (app/api/billing/webhook). Get it from
# https://dashboard.stripe.com/webhooks (or `stripe listen` in local dev). The
# webhook route REQUIRES this to verify Stripe signatures.
# STRIPE_WEBHOOK_SECRET="whsec_..."
# Recurring Price IDs for the premium subscription (Stripe → Products → Prices).
# STRIPE_PRICE_MONTHLY="price_..."
# STRIPE_PRICE_YEARLY="price_..."
#
# The Stripe Customer Portal (app/api/billing/portal) returns users to
# NEXT_PUBLIC_APP_URL/billing; configure the portal itself at
# https://dashboard.stripe.com/settings/billing/portal — no extra env var needed.
#
# Legacy compatibility only; prefer CAMPFIRE_EDITION="community":
# SELF_HOSTED="true"

# ─── Quick Start ───
# 1. npm install
# 2. npm run build
# 3. npm run host          <-- auto-detects your IP, others connect via LAN
#
# For internet access: use a reverse proxy/tunnel or deploy to a VPS. WebRTC
# voice still needs a tested TURN service across restrictive networks.
