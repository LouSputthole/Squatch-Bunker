# ─── Database ───
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/campfire?schema=public"

# ─── Auth ───
# CHANGE THIS in production — generate with: openssl rand -hex 32
JWT_SECRET="campfire-secret-change-me-in-production"
# Cookie name (change if running multiple instances)
# COOKIE_NAME="squatch-token"

# ─── Server URLs ───
# App URL — where the Next.js frontend is served
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Socket.IO URL — where the realtime server is served
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
# Socket.IO port (for the realtime server process)
SOCKET_PORT=3001

# ─── Socket.IO Path ───
# Change if running behind a reverse proxy that remaps the path
# SOCKET_PATH="/api/socketio"
# NEXT_PUBLIC_SOCKET_PATH="/api/socketio"

# ─── CORS ───
# Comma-separated origins allowed to connect to the realtime server
# Defaults to NEXT_PUBLIC_APP_URL if not set
# CORS_ORIGINS="https://campfire.example.com,https://www.campfire.example.com"

# ─── Upload Limits ───
# MAX_AVATAR_SIZE=2097152    # 2MB
# MAX_UPLOAD_SIZE=10485760   # 10MB

# ─── Production Notes ───
# When deploying to a server:
# 1. Set NODE_ENV=production (enables Secure cookies, optimized builds)
# 2. Generate a strong JWT_SECRET
# 3. Set NEXT_PUBLIC_APP_URL to your domain (https://campfire.yourdomain.com)
# 4. Set NEXT_PUBLIC_SOCKET_URL to your socket endpoint
# 5. Set CORS_ORIGINS if frontend and socket are on different domains
# 6. Use a strong DATABASE_URL with proper credentials
