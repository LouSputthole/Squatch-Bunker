# Database connection (matches Docker container from pnpm db:up)
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/squatchchat?schema=public"

# JWT secret for auth tokens — CHANGE THIS in production
JWT_SECRET="squatch-secret-change-me-in-production"

# Socket.IO realtime server
SOCKET_PORT=3001
NEXT_PUBLIC_SOCKET_URL="http://localhost:3001"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
