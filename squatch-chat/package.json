{
  "name": "campfire",
  "version": "0.1.0-beta.1",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:realtime": "tsx watch realtime/server.ts",
    "dev:full": "node scripts/dev-full.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "build": "node scripts/build.mjs",
    "release:check": "node scripts/check-release-metadata.mjs",
    "start": "next start",
    "host": "npx tsx server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "setup": "node scripts/postinstall.mjs",
    "db:up": "node scripts/db-up.mjs",
    "db:down": "node scripts/db-down.mjs",
    "db:wait": "node scripts/db-wait.mjs",
    "db:migrate": "tsx scripts/preflight-postgresql.ts && prisma migrate deploy --config prisma.postgresql.config.ts",
    "db:migrate:dev": "prisma migrate dev --config prisma.postgresql.config.ts",
    "db:generate": "node scripts/generate-prisma.mjs",
    "db:check": "node scripts/check-prisma-pipeline.mjs",
    "db:sync": "node scripts/sync-sqlite.mjs",
    "db:fixture:sqlite-v0.0.3": "node scripts/create-v003-sqlite-fixture.mjs",
    "db:verify:sqlite": "tsx scripts/verify-sqlite.ts",
    "db:verify:postgresql": "tsx scripts/verify-postgresql.ts",
    "db:verify:postgresql-baseline": "tsx scripts/verify-postgresql-baseline.ts",
    "db:push": "prisma db push --config prisma.config.ts",
    "db:studio": "prisma studio --config prisma.config.ts",
    "db:reset": "prisma db push --config prisma.config.ts --force-reset",
    "desktop:stage": "node packaging/stage-desktop.mjs",
    "desktop:verify": "node packaging/verify-desktop.mjs",
    "desktop:run": "npm run desktop:stage && electron desktop",
    "desktop:portable": "npm run desktop:stage && electron-builder --config packaging/electron-builder.json --win portable --x64",
    "desktop:installer": "npm run desktop:stage && electron-builder --config packaging/electron-builder.json --win nsis --x64",
    "desktop:dist": "npm run desktop:stage && electron-builder --config packaging/electron-builder.json --win portable nsis --x64",
    "runtime:verify:realtime": "tsx scripts/verify-realtime.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "7.8.0",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.0",
    "jsonwebtoken": "^9.0.3",
    "next": "^16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "stripe": "^22.3.1"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "postcss": "8.5.16"
  },
  "devDependencies": {
    "@electron/rebuild": "4.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "esbuild": "0.28.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "prisma": "7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
