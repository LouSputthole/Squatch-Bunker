{
  "name": "squatch-chat",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:realtime": "tsx watch realtime/server.ts",
    "dev:full": "bash ./scripts/dev-full.sh",
    "postinstall": "bash scripts/postinstall.sh || prisma generate",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "setup": "bash ./scripts/setup.sh",
    "db:up": "bash ./scripts/db-up.sh",
    "db:down": "bash ./scripts/db-down.sh",
    "db:wait": "bash ./scripts/db-wait.sh",
    "db:migrate": "dotenv -e .env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env -- prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
