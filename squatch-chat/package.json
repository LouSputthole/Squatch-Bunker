{
  "name": "campfire",
  "version": "0.0.3",
  "private": true,
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:realtime": "tsx watch realtime/server.ts",
    "dev:full": "node scripts/dev-full.mjs",
    "postinstall": "node scripts/postinstall.mjs",
    "build": "node scripts/build.mjs",
    "start": "next start",
    "host": "npx tsx server.ts",
    "lint": "eslint",
    "test": "vitest run",
    "setup": "node scripts/postinstall.mjs",
    "db:up": "node scripts/db-up.mjs",
    "db:down": "node scripts/db-down.mjs",
    "db:wait": "node scripts/db-wait.mjs",
    "db:migrate": "dotenv -e .env -- prisma migrate deploy",
    "db:migrate:dev": "dotenv -e .env -- prisma migrate dev",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env -- prisma db push",
    "db:studio": "dotenv -e .env -- prisma studio",
    "db:reset": "dotenv -e .env -- prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "cookie": "^1.1.1",
    "dotenv": "^17.4.0",
    "jsonwebtoken": "^9.0.3",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "@prisma/engines",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie": "^1.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "prisma": "^7.6.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
